generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         String   @default("ADMIN")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id          String        @id @default(uuid())
  title       String
  slug        String        @unique
  summary     String
  description String?
  status      ProjectStatus @default(DRAFT)
  featured    Boolean       @default(false)
  coverImage  String?
  repository  String?
  demoUrl     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}